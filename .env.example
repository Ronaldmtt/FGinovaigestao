SESSION_SECRET=substitua_por_sua_chave_secreta_segura
DATABASE_URL=postgresql://usuario:senha@localhost/gestao_inovailab

# Configurações de Banco de Dados (Postgres Production)
PGDATABASE=gestao_inovailab
PGHOST=localhost
PGPORT=5432
PGUSER=gestao_user
PGPASSWORD=sua_senha_segura

# Configurações de Email
MAIL_USERNAME=seu_email@exemplo.com
MAIL_PASSWORD=sua_senha_app_email

# OpenAI
OPENAI_API_KEY=sua_chave_api_openai
OPENAI_MODEL=gpt-4o-mini

# FG Transcritor (CRM 2 - Reuniões)
FGTRANSCRITOR_API_KEY=fgtranscritorpass
FGTRANSCRITOR_BASE_URL=https://inovaimeet.com
FGTRANSCRITOR_HUB_EMAIL=hub@inovailab.com

# SMTP Configurações adicionais
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_DEFAULT_SENDER=GESTÃO INOVA <seu_email@exemplo.com>

# Monitoramento RPA (Opcional)
RPA_MONITOR_HOST=wss://app-in-sight.replit.app/ws
RPA_MONITOR_ID=APP-GESTAO-PROD
RPA_MONITOR_REGION=Sudeste
RPA_MONITOR_TRANSPORT=ws
RPA_MONITOR_ENABLED=true
