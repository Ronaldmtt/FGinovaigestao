# ==============================
# Core Flask / Database
# ==============================
SESSION_SECRET=troque_por_uma_chave_secreta_forte
DATABASE_URL=postgresql://usuario:senha@localhost/gestao_inovailab

# Configurações de Banco de Dados (Postgres Production)
PGDATABASE=gestao_inovailab
PGHOST=localhost
PGPORT=5432
PGUSER=gestao_user
PGPASSWORD=troque_pela_senha_do_banco

# ==============================
# OpenAI
# ==============================
OPENAI_API_KEY=substitua_pela_sua_chave_openai
OPENAI_MODEL=gpt-4o-mini

# ==============================
# SMTP / EMAIL (Gmail)
# Use senha de app do Google, nunca a senha principal da conta.
# ==============================
MAIL_USERNAME=seu_email@exemplo.com
MAIL_PASSWORD=senha_de_app_do_google
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_DEFAULT_SENDER="GESTAO INOVA <seu_email@exemplo.com>"

# ==============================
# Google OAuth (Google Calendar / Reuniões)
# ==============================
GOOGLE_OAUTH_CLIENT_ID=seu_client_id.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=seu_client_secret
REDIRECT_URI=https://seu-dominio.com/oauth2callback

# Integração compartilhada opcional do hub (obtida via scripts/get_google_hub_refresh_token.py)
GOOGLE_SHARED_ACCOUNT_EMAIL=hub@seudominio.com
GOOGLE_SHARED_REFRESH_TOKEN=refresh_token_do_hub

# ==============================
# FG Transcritor (Reuniões + Transcrição)
# ==============================
FGTRANSCRITOR_API_KEY=troque_pela_chave_do_transcritor
FGTRANSCRITOR_HUB_EMAIL=hub@seudominio.com
FGTRANSCRITOR_BASE_URL=https://inovaimeet.com
FGTRANSCRITOR_COLLECTION_PATH=fgtranscritor_api.postman_collection.json
FGTRANSCRITOR_GET_TRANSCRIPT_PATH=/api/get_transcript
FGTRANSCRITOR_CREATE_MEETING_PATH=
FGTRANSCRITOR_AUTH_HEADER=X-API-Key
FGTRANSCRITOR_AUTH_SCHEME=
FGTRANSCRITOR_FORCE_URL=

# ==============================
# RPA Monitor (Opcional)
# ==============================
RPA_MONITOR_ENABLED=true
RPA_MONITOR_HOST=wss://appinsight.com.br/ws
RPA_MONITOR_ID=APP-GESTAO-INOVAILAB
RPA_MONITOR_REGION=Sudeste
RPA_MONITOR_TRANSPORT=ws
RPA_MONITOR_URL=https://appinsight.com.br

# ==============================
# Transcrição (TTL e refresh)
# ==============================
TRANSCRIPT_TTL_DAYS=7
TRANSCRIPT_CLEANUP_INTERVAL_HOURS=24
TRANSCRIPT_MIN_REFRESH_INTERVAL_SECONDS=15
