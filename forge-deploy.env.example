# Configuração local do deploy automático do FGInovaigestao.
# Copie este arquivo para forge-deploy.env na máquina Windows do projeto.
# O arquivo forge-deploy.env deve ficar fora do Git/ignorado, pois pode conter caminhos e comandos locais.

PROJECT_NAME=FGInovaigestao
GIT_REMOTE=origin
GIT_BRANCH=main

# Este projeto roda como serviço Windows via NSSM.
SERVICE_MANAGER=nssm
SERVICE_NAME=GestaoInova

# Comandos opcionais executados APENAS quando houver commit novo no Git.
# Deixe vazio se não precisar.
PRE_DEPLOY_COMMAND=
BUILD_COMMAND=
MIGRATE_COMMAND=

# Healthcheck opcional. Se tiver uma URL local estável, configure aqui.
# Exemplos:
# HEALTHCHECK_URL=http://127.0.0.1:5000/
# HEALTHCHECK_URL=http://localhost:5000/health
HEALTHCHECK_URL=
HEALTHCHECK_ATTEMPTS=6
HEALTHCHECK_DELAY_SECONDS=5
